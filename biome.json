{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "!**/.superpowers",
      "!**/.next",
      "!**/dist",
      "!**/.turbo",
      "!**/.nx",
      "!**/dev-dist",
      "!**/.zed",
      "!**/.vscode",
      "!**/routeTree.gen.ts",
      "!**/src-tauri",
      "!**/.nuxt",
      "!bts.jsonc",
      "!**/.expo",
      "!**/.wrangler",
      "!**/.alchemy",
      "!**/.svelte-kit",
      "!**/wrangler.jsonc",
      "!**/.source",
      "!**/convex/_generated",
      "!**/target",
      "!apps/ios"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useExhaustiveDependencies": "info"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cva", "cn"]
          }
        }
      },
      "style": {
        "noParameterAssign": "error",
        "useAsConstAssertion": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/docs/src/routes/$lang.tsx",
        "apps/docs/src/routes/$lang/docs/$.tsx",
        "apps/docs/src/routes/llms*",
        "apps/web/src/routes/_authed/terminal.$serverId.tsx",
        "apps/web/src/routes/_authed/network/$serverId.tsx",
        "apps/web/src/routes/_authed/files.$serverId.tsx",
        "apps/web/src/routes/status.$slug.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/docs/src/lib/cn.ts",
        "packages/db/src/schema/index.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/web/src/components/ui/chart.tsx"],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/web/src/components/data-table/**",
        "apps/web/src/components/ui/calendar.tsx",
        "apps/web/src/components/ui/command.tsx",
        "apps/web/src/components/ui/input-group.tsx",
        "apps/web/src/components/ui/popover.tsx",
        "apps/web/src/components/ui/slider.tsx",
        "apps/web/src/components/ui/textarea.tsx",
        "apps/web/src/config/data-table.ts",
        "apps/web/src/hooks/use-callback-ref.ts",
        "apps/web/src/hooks/use-data-table.ts",
        "apps/web/src/hooks/use-debounced-callback.ts",
        "apps/web/src/lib/data-table.ts",
        "apps/web/src/lib/format.ts",
        "apps/web/src/lib/parsers.ts",
        "apps/web/src/types/data-table.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off",
            "useTopLevelRegex": "off"
          },
          "style": {
            "noNestedTernary": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          },
          "complexity": {
            "noVoid": "off"
          },
          "correctness": {
            "noNestedComponentDefinitions": "off"
          },
          "a11y": {
            "useSemanticElements": "off",
            "useKeyWithClickEvents": "off",
            "noNoninteractiveElementInteractions": "off"
          }
        }
      }
    }
  ],
  "extends": ["ultracite/biome/core", "ultracite/biome/react"]
}
